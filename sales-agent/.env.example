# Sales Agent Configuration
MONITORED_EMAIL=koustubh014@gmail.com
FORWARD_TO=atsit17@gmail.com
CHECK_INTERVAL_SECONDS=60
OUTLOOK_FOLDER=Inbox
LOG_LEVEL=INFO

# Mail Client Mode: "outlook" (COM interface, requires Outlook Desktop) or "imap" (cross-platform, directly connects to mail server)
MAIL_CLIENT_MODE=imap

# IMAP Backend Settings (Only required if MAIL_CLIENT_MODE=imap)
# Common hosts: "imap.gmail.com" (Gmail), "outlook.office365.com" (Outlook/Hotmail)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
# Note: For Gmail, you MUST use an "App Password" (generated in Google Account Security settings) rather than your standard login password.
IMAP_PASSWORD=your_app_password_here

# RFQ Keywords (comma-separated)
RFQ_KEYWORDS=rfq,request for quotation,request for quote,quotation request,price inquiry,price enquiry,quote request,bid request,tender
FUZZY_MATCH_THRESHOLD=80

# Direct API Delivery Config (Default)
API_INGEST_URL=http://192.168.11.86/api/v1/emails/submit
DELIVERY_METHOD=api
